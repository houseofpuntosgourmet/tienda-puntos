{
  "version": 2,
  "buildCommand": "cd web-admin && npm run build",
  "outputDirectory": "web-admin/dist",
  "env": {
    "BACKEND_URL": "https://tienda-puntos-backend.railway.app"
  },
  "functions": {
    "api/proxy.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/proxy.js?path=$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "^/(?!api/).*$",
      "dest": "/index.html"
    }
  ],
  "experimentalServices": []
}
