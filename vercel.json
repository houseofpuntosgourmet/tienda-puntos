{
    "builds":  [
                   {
                       "config":  {
                                      "runtime":  "nodejs18.x"
                                  },
                       "use":  "@vercel/node",
                       "src":  "backend/src/index.ts"
                   }
               ],
    "routes":  [
                   {
                       "src":  "/(.*)",
                       "dest":  "backend/src/index.ts"
                   }
               ],
    "env":  {
                "NODE_ENV":  "production",
                "PORT":  "3001",
                "DATABASE_URL":  "@database_url"
            }
}
